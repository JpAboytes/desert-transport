{
  "expo": {
    "name": "Transporte App",
    "slug": "transporte-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "transporte",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.deserttransport.app"
    },
    "android": {
      "package": "com.deserttransport.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#0a0a0a"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "24ceda7b-3d14-49c6-938c-a3f2d74e46e9"
      }
    },
    "owner": "jpdessens"
  }
}
